# Postgres (Neon) — conexão completa
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=planevidences
# URL pública do bucket (ex: https://pub-xxxx.r2.dev)
R2_PUBLIC_URL=

# CORS — domínios separados por vírgula. Vazio = aberto (apenas em dev).
ALLOWED_ORIGINS=https://planevidences.vercel.app

# Porta (Render seta automaticamente)
PORT=3001
