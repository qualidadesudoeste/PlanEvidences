# =============================================================================
# PlanEvidences — backend (.env)
# Copie para .env e preencha. Linhas em branco/comentadas usam o default do código.
# =============================================================================

# Porta HTTP (default: 4500). Em produção no Smart Sig Runner usamos 4500.
PORT=4500

# CORS — domínios separados por vírgula. Vazio = somente mesma origem.
# Em deploy unificado (frontend servido pelo Express na mesma porta) NÃO precisa setar.
# Só preencha se o frontend roda em outro host (ex: Vercel + Render).
# ALLOWED_ORIGINS=https://planevidences.vercel.app,http://localhost:5173

# -----------------------------------------------------------------------------
# IA (opcional — se setar, vira default e dispensa key do navegador)
# Pelo menos uma das três funciona; se setar várias, prioridade: openai > anthropic > gemini
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# -----------------------------------------------------------------------------
# Integração SIG v3 (publicação direta de corretivas)
# Cada usuário entra no PlanEvidences com seu próprio usuário e senha do SIG.
# A senha é apenas encaminhada no login e não é armazenada.
# -----------------------------------------------------------------------------
SIG_API_URL=https://sigv3.sudoesteinformatica.com.br/sig_v3
SIG_WEB_URL=https://sigv3.sudoesteinformatica.com.br
# ID atual de "Retrabalho / Correção de erros". O nome também é validado no lookup.
SIG_CORRECTIVE_ACTIVITY_ID=10
SIG_TIMEOUT_MS=60000
SIG_LOOKUPS_CACHE_MS=300000

# Sessão local do PlanEvidences (em memória; reiniciar o serviço encerra as sessões).
SESSION_TTL_HOURS=8
# false enquanto o serviço estiver somente em HTTP na rede interna.
# Ao habilitar HTTPS, altere obrigatoriamente para true.
SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_NAME=planevidences_session

# -----------------------------------------------------------------------------
# Storage de imagens (R2 / S3 / Supabase Storage / MinIO)
# Só precisa pro Editor de Evidências (upload de prints).
# Sem isso, o gerador de casos roda normalmente.
# -----------------------------------------------------------------------------
# Supabase: Settings → Storage → S3 Connection
STORAGE_ENDPOINT=https://SEU-PROJETO.supabase.co/storage/v1/s3
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=planevidences
# URL pública do bucket
# Supabase: https://SEU-PROJETO.supabase.co/storage/v1/object/public/planevidences
# R2:       https://pub-xxxx.r2.dev
STORAGE_PUBLIC_URL=https://SEU-PROJETO.supabase.co/storage/v1/object/public/planevidences

# -----------------------------------------------------------------------------
# Postgres (histórico de documentos LaTeX/PDF gerados)
# Só precisa pra listar/abrir documentos antigos no Editor de Evidências.
# Sem isso, gera PDF mas não fica no histórico.
# -----------------------------------------------------------------------------
# Supabase: Settings → Database → Connection string (URI, modo "pooler")
# Neon:     Dashboard → Connection string
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
