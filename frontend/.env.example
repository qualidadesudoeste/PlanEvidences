# =============================================================================
# PlanEvidences — frontend (.env)
# Vite lê estas vars em BUILD TIME (npm run build) e embute no bundle.
# Mudou? roda npm run build de novo.
# =============================================================================

# URL pública do backend.
# - Deploy unificado (Smart Sig Runner): DEIXE VAZIO. Frontend e API são servidos
#   pelo mesmo Node na porta 4500, então fetch('/api/...') resolve sozinho.
# - Deploy separado (Vercel + Render): aponte pra URL pública do backend.
#   Exemplo: VITE_API_URL=https://planevidences-backend.onrender.com
VITE_API_URL=

# Supabase (banco + storage do QA Assistant + planos salvos).
# Settings → API no dashboard do Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
