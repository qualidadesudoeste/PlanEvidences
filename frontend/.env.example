# URL pública do backend em produção (Render/Railway/Fly/etc).
# Deixe vazio em dev (o Vite faz proxy via vite.config.ts).
# Exemplo: VITE_API_URL=https://planevidences-backend.onrender.com
VITE_API_URL=

# Supabase compartilhado com o QA Assistant (https://qa-assistant-hu.vercel.app).
# Necessário para a feature "Importar do QA Assistant".
# Pegue em Supabase Dashboard → Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
